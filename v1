<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Armchair Insider — Weekly Buy Summary · May 11–17, 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --gold:       #C9A84C;
  --gold-lt:    #E8C97A;
  --gold-pale:  #FBF5E6;
  --gold-dim:   #A07830;
  --ink:        #18150F;
  --ink-mid:    #3D3628;
  --ink-lt:     #7A6F5E;
  --surface:    #FDFCF8;
  --surface-2:  #F5F0E6;
  --surface-3:  #EDE4D0;
  --border:     #E2D8C2;
  --green:      #1F6B47;
  --green-lt:   #E6F4ED;
  --amber:      #9E5A0A;
  --amber-lt:   #FEF0DC;
  --red:        #8B1A1A;
  --red-lt:     #FDECEC;
  --blue:       #1A3F6F;
  --r:          12px;
  --rs:         7px;
  --sh:         0 2px 14px rgba(24,21,15,.07);
  --sh-md:      0 6px 28px rgba(24,21,15,.11);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--surface);color:var(--ink);line-height:1.65;font-size:15px;}

/* ── HERO ── */
.hero{
  background:var(--ink);
  background-image:
    radial-gradient(ellipse 70% 55% at 65% 130%, rgba(201,168,76,.20) 0%,transparent 65%),
    radial-gradient(ellipse 45% 45% at 5% 5%,   rgba(201,168,76,.08) 0%,transparent 55%);
  padding:60px 24px 52px;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;pointer-events:none;
  background-image:
    repeating-linear-gradient(90deg,transparent,transparent 56px,rgba(201,168,76,.025) 56px,rgba(201,168,76,.025) 57px),
    repeating-linear-gradient(0deg,  transparent,transparent 56px,rgba(201,168,76,.025) 56px,rgba(201,168,76,.025) 57px);
}
.hero-eyebrow{
  display:inline-flex;align-items:center;gap:8px;
  background:rgba(201,168,76,.13);border:1px solid rgba(201,168,76,.32);
  color:var(--gold-lt);font-family:'DM Mono',monospace;font-size:11px;
  letter-spacing:.13em;text-transform:uppercase;padding:5px 14px;border-radius:100px;margin-bottom:26px;
}
.hero-eyebrow::before{content:'▲';font-size:8px;}
.hero h1{
  font-family:'Playfair Display',serif;font-size:clamp(28px,5.5vw,54px);
  color:#fff;line-height:1.12;letter-spacing:-.01em;margin-bottom:10px;
}
.hero h1 em{font-style:italic;color:var(--gold-lt);}
.hero-date{
  font-family:'DM Mono',monospace;font-size:12px;letter-spacing:.1em;
  text-transform:uppercase;color:rgba(255,255,255,.45);margin-bottom:18px;
}
.hero-desc{max-width:540px;margin:0 auto 22px;color:rgba(255,255,255,.65);font-size:15px;line-height:1.78;}
.hero-disc{
  display:inline-block;background:rgba(255,255,255,.05);
  border:1px solid rgba(255,255,255,.11);color:rgba(255,255,255,.4);
  font-size:11.5px;padding:8px 18px;border-radius:6px;font-family:'DM Mono',monospace;
}

/* ── LAYOUT ── */
.wrap{max-width:1120px;margin:0 auto;padding:0 20px;}
.section{padding:48px 0;}
.sec-eye{font-family:'DM Mono',monospace;font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:6px;}
.sec-title{font-family:'Playfair Display',serif;font-size:26px;letter-spacing:-.01em;margin-bottom:6px;}
.sec-sub{color:var(--ink-lt);font-size:13.5px;margin-bottom:26px;}
.rule{height:2px;width:80px;background:linear-gradient(90deg,var(--gold),transparent);margin-bottom:26px;border-radius:2px;}

/* ── METRIC CARDS ── */
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:13px;}
.m-card{
  background:#fff;border:1px solid var(--border);border-radius:var(--r);
  padding:22px 18px;box-shadow:var(--sh);position:relative;overflow:hidden;
  transition:box-shadow .18s,transform .18s;
}
.m-card:hover{box-shadow:var(--sh-md);transform:translateY(-2px);}
.m-card::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold),var(--gold-lt));}
.m-label{font-family:'DM Mono',monospace;font-size:10.5px;letter-spacing:.1em;text-transform:uppercase;color:var(--ink-lt);margin-bottom:10px;}
.m-val{font-family:'Playfair Display',serif;font-size:30px;color:var(--ink);line-height:1.1;margin-bottom:4px;}
.m-val.gold{color:var(--gold-dim);}
.m-val.green{color:var(--green);}
.m-meta{font-size:12px;color:var(--ink-lt);line-height:1.5;}

/* ── TOP ACTIVITY ── */
.top-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:14px;}
.top-card{
  background:#fff;border:1px solid var(--border);border-radius:var(--r);
  padding:22px 20px;box-shadow:var(--sh);
}
.top-card.featured{border-color:var(--gold);background:var(--gold-pale);}
.top-card-head{display:flex;align-items:flex-start;justify-content:space-between;gap:10px;margin-bottom:14px;}
.top-ticker{
  font-family:'DM Mono',monospace;font-size:20px;font-weight:500;
  background:var(--ink);color:var(--gold-lt);
  padding:4px 12px;border-radius:5px;letter-spacing:.04em;
}
.featured .top-ticker{background:var(--gold);color:var(--ink);}
.mention-badge{
  display:inline-flex;align-items:center;gap:5px;
  background:var(--gold-pale);border:1px solid var(--gold);
  color:var(--gold-dim);font-family:'DM Mono',monospace;font-size:11px;
  padding:4px 10px;border-radius:100px;white-space:nowrap;
}
.mention-badge .dot{width:6px;height:6px;background:var(--gold);border-radius:50%;}
.top-name{font-size:13.5px;font-weight:500;color:var(--ink-mid);margin-bottom:6px;}
.top-meta{display:flex;gap:10px;flex-wrap:wrap;}
.top-pill{
  font-size:11px;font-family:'DM Mono',monospace;
  background:var(--surface-2);border:1px solid var(--border);
  padding:3px 9px;border-radius:100px;color:var(--ink-mid);
}
.top-pill.green{background:var(--green-lt);border-color:#A3D4BC;color:var(--green);}
.top-interpret{
  background:var(--surface-2);border-left:3px solid var(--gold);
  padding:16px 18px;border-radius:0 var(--rs) var(--rs) 0;
  margin-top:22px;font-size:13.5px;color:var(--ink-mid);line-height:1.75;
}

/* ── CHARTS ── */
.chart-bg{background:var(--surface-2);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.charts-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(460px,1fr));gap:18px;}
@media(max-width:580px){.charts-grid{grid-template-columns:1fr;}}
.c-card{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:22px;box-shadow:var(--sh);}
.c-title{font-family:'Playfair Display',serif;font-size:16px;margin-bottom:3px;}
.c-sub{font-size:11.5px;color:var(--ink-lt);font-family:'DM Mono',monospace;margin-bottom:18px;}
.c-wrap{position:relative;}

/* ── TABLE ── */
.tbl-ctrl{display:flex;gap:10px;margin-bottom:13px;flex-wrap:wrap;align-items:center;}
.s-box{
  flex:1;min-width:170px;padding:9px 13px;
  border:1px solid var(--border);border-radius:var(--rs);
  font-family:'DM Sans',sans-serif;font-size:13px;background:#fff;color:var(--ink);outline:none;
  transition:border-color .18s;
}
.s-box:focus{border-color:var(--gold);}
.f-btn{
  padding:9px 13px;border:1px solid var(--border);border-radius:var(--rs);
  background:#fff;font-family:'DM Mono',monospace;font-size:10.5px;letter-spacing:.07em;
  cursor:pointer;color:var(--ink-mid);transition:all .15s;text-transform:uppercase;
}
.f-btn:hover,.f-btn.active{background:var(--ink);color:var(--gold-lt);border-color:var(--ink);}
.r-count{font-family:'DM Mono',monospace;font-size:12px;color:var(--ink-lt);margin-left:auto;}
.tbl-wrap{overflow-x:auto;border-radius:var(--r);border:1px solid var(--border);box-shadow:var(--sh);}
table{width:100%;border-collapse:collapse;background:#fff;font-size:13.5px;}
thead tr{background:var(--ink);}
thead th{
  padding:13px 13px;text-align:left;color:rgba(255,255,255,.7);
  font-family:'DM Mono',monospace;font-size:10.5px;letter-spacing:.09em;
  text-transform:uppercase;white-space:nowrap;cursor:pointer;user-select:none;transition:color .15s;
}
thead th:hover{color:var(--gold-lt);}
thead th.sa::after{content:' ↑';color:var(--gold-lt);}
thead th.sd::after{content:' ↓';color:var(--gold-lt);}
tbody tr{border-bottom:1px solid var(--border);transition:background .1s;}
tbody tr:last-child{border-bottom:none;}
tbody tr:hover{background:var(--gold-pale);}
tbody tr.hi{background:var(--gold-pale);}
tbody tr.hi:hover{background:#F0E4C6;}
td{padding:11px 13px;vertical-align:middle;}
.rank-c{font-family:'DM Mono',monospace;font-size:12px;color:var(--ink-lt);width:32px;}
.hi .rank-c{color:var(--gold-dim);font-weight:700;}
.t-badge{
  display:inline-block;background:var(--ink);color:var(--gold-lt);
  font-family:'DM Mono',monospace;font-size:12px;padding:3px 8px;border-radius:4px;letter-spacing:.04em;
}
.hi .t-badge{background:var(--gold);color:var(--ink);}
.name-c{color:var(--ink-mid);max-width:210px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.yield-v{font-family:'DM Mono',monospace;font-weight:600;color:var(--green);font-size:13px;}
.yield-hi{color:var(--amber);}
.yield-ex{color:var(--red);}
.tag{
  display:inline-block;font-size:10px;font-family:'DM Mono',monospace;
  padding:1px 6px;border-radius:3px;margin-left:5px;vertical-align:middle;
  letter-spacing:.05em;white-space:nowrap;
}
.tag-hi{background:var(--amber-lt);border:1px solid #F6C07A;color:var(--amber);}
.tag-ex{background:var(--red-lt);border:1px solid #EFAAAA;color:var(--red);}
.alloc-v{font-family:'DM Mono',monospace;font-size:13px;color:var(--ink-mid);}
.type-pill{
  display:inline-block;background:var(--surface-2);border:1px solid var(--border);
  font-size:11px;padding:2px 8px;border-radius:100px;color:var(--ink-mid);white-space:nowrap;
}
.men-wrap{display:flex;align-items:center;gap:7px;}
.men-num{font-family:'DM Mono',monospace;font-size:13px;font-weight:500;min-width:16px;}
.men-bar{height:6px;background:linear-gradient(90deg,var(--gold),var(--gold-lt));border-radius:3px;min-width:4px;}

/* ── YIELD LINK ── */
.yield-link{
  display:inline-flex;align-items:center;gap:5px;
  text-decoration:none;border-radius:4px;padding:2px 4px 2px 0;
  transition:opacity .15s;
}
.yield-link:hover{opacity:.75;}
.sa-icon{
  font-size:10px;color:var(--gold-dim);opacity:.7;
  font-family:'DM Mono',monospace;
}

/* ── ANALYSIS ── */
.ana-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:15px;}
.ana-block{background:#fff;border:1px solid var(--border);border-radius:var(--r);padding:22px;box-shadow:var(--sh);}
.ana-block h3{font-family:'Playfair Display',serif;font-size:17px;margin-bottom:10px;display:flex;align-items:center;gap:9px;}
.ana-icon{width:28px;height:28px;background:var(--gold-pale);border-radius:6px;display:inline-flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.ana-block p{color:var(--ink-mid);font-size:13.5px;line-height:1.78;}
.callout{background:var(--amber-lt);border-left:3px solid var(--amber);padding:12px 15px;border-radius:0 var(--rs) var(--rs) 0;margin-top:11px;font-size:13px;color:var(--ink-mid);}
.callout strong{color:var(--amber);}

/* ── FOOTER ── */
footer{background:var(--ink);color:rgba(255,255,255,.35);text-align:center;padding:34px 24px;font-size:12px;font-family:'DM Mono',monospace;line-height:2.1;}
footer span{color:rgba(201,168,76,.65);}

@media(max-width:768px){
  .hero{padding:46px 18px 38px;}
  .metrics{grid-template-columns:repeat(2,1fr);}
  .top-grid,.ana-grid{grid-template-columns:1fr;}
  .name-c{max-width:140px;}
}
@media(max-width:420px){
  .metrics{grid-template-columns:1fr 1fr;}
}
</style>
</head>
